<?xml version="1.0"?>
<robot name="test_robot">

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <material name="gray">
    <color rgba="0.2 0.2 0.2 1"/>
  </material>

  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>

  <link name="base_link">
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 -0.03"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file:///home/shourya007/miniprjct_ws/src/mobile_robot/meshes/chassis.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.8 0.6 0.01"/>
      </geometry>
    </collision>
  </link>

  <link name="bumpers">
    <visual>
      <geometry>
        <mesh filename="file:///home/shourya007/miniprjct_ws/src/mobile_robot/meshes/Bumpers.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="livery">
    <visual>
      <geometry>
        <mesh filename="file:///home/shourya007/miniprjct_ws/src/mobile_robot/meshes/livery.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="green"/>
    </visual>
  </link>

  <link name="top_plates">
    <visual>
      <geometry>
        <mesh filename="file:///home/shourya007/miniprjct_ws/src/mobile_robot/meshes/Top_plates.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="left_wheel">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.02" ixy="0" ixz="0"
         iyy="0.02" iyz="0"
         izz="0.04"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file:///home/shourya007/miniprjct_ws/src/mobile_robot/meshes/wheel.stl" scale="0.001 0.001 0.001"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 3.14"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.17" length="0.1"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.5</mu>
            <mu2>1.5</mu2>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <link name="right_wheel">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.02" ixy="0" ixz="0"
         iyy="0.02" iyz="0"
         izz="0.04"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file:///home/shourya007/miniprjct_ws/src/mobile_robot/meshes/wheel.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.17" length="0.1"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.5</mu>
            <mu2>1.5</mu2>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <link name="caster_wheel">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file:///home/shourya007/miniprjct_ws/src/mobile_robot/meshes/Castor_wheel.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0.28 -0.1 -0.015"/>
      <geometry>
        <box size="0.158 0.158 0.137"/>
      </geometry>
    </collision>
  </link>

  <link name="camera">
    <visual>
      <geometry>
        <mesh filename="file:///home/shourya007/miniprjct_ws/src/mobile_robot/meshes/camera.stl" scale="0.0001 0.0001 0.0001"/>
      </geometry>
      <material name="green"/>
    </visual>
  </link>

  <link name="lidar">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/shourya007/miniprjct_ws/src/mobile_robot/meshes/lidar.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <link name="base_footprint"/>

    <joint name="base_footprint_joint" type="fixed">

      <parent link="base_footprint"/>
      <child link="base_link"/>

      <origin xyz="0 0 0" rpy="0 0 0"/>

    </joint>

  <joint name="bumper_joint" type="fixed">
    <parent link="base_link"/>
    <child link="bumpers"/>
  </joint>

  <joint name="livery_joint" type="fixed">
    <parent link="base_link"/>
    <child link="livery"/>
  </joint>

  <joint name="top_plates_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_plates"/>
  </joint>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.256 -0.29 0.036"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.256 0.29 0.036"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="-0.16 0.05 -0.049"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <parent link="top_plates"/>
    <child link="camera"/>
    <origin xyz="0.066 0.2 0.3" rpy="0 0 1.57"/>
  </joint>

  <joint name="lidar_joint" type="fixed">
    <parent link="top_plates"/>
    <child link="lidar"/>
    <origin xyz="0.42 0.0 0.4" rpy="0 0 0"/> 
  </joint>
  <gazebo>

    <!-- ✅ DIFF DRIVE -->
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
  
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
  
      <wheel_separation>0.58</wheel_separation>
      <wheel_diameter>0.34</wheel_diameter>
  
      <command_topic>/cmd_vel</command_topic>
  
      <!-- ✅ REQUIRED FOR SLAM -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
  
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
  
      <robot_base_frame>base_footprint</robot_base_frame>
  
      <update_rate>50</update_rate>
  
      <max_wheel_torque>50</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration>
  
    </plugin>
  
    <!-- ✅ JOINT STATE PUBLISHER -->
    <plugin name="joint_state_publisher"
            filename="libgazebo_ros_joint_state_publisher.so">
  
      <ros>
        <namespace>/</namespace>
      </ros>
  
      <update_rate>50</update_rate>
  
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
  
    </plugin>
  
  </gazebo>
  
  <!-- MATERIALS -->
  <gazebo reference="base_link">
    <material>Gazebo/Gray</material>
  </gazebo>
  
  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="caster_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="bumpers">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="livery">
    <material>Gazebo/Green</material>
  </gazebo>
  
  <gazebo reference="top_plates">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="camera">
    <material>Gazebo/Gray</material>
  </gazebo>
  
  <gazebo reference="lidar">
    <material>Gazebo/Gray</material>
  </gazebo>
  
  <!-- CAMERA -->
  <gazebo reference="camera">
  
    <sensor type="camera" name="camera_sensor">
  
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>30</update_rate>
  
      <camera>
  
        <horizontal_fov>1.396</horizontal_fov>
  
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
  
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
  
      </camera>
  
      <plugin name="camera_controller"
              filename="libgazebo_ros_camera.so">
  
        <ros>
          <namespace>/camera</namespace>
        </ros>
  
        <camera_name>camera</camera_name>
  
        <image_topic_name>image_raw</image_topic_name>
  
        <camera_info_topic_name>camera_info</camera_info_topic_name>
  
        <frame_name>camera</frame_name>
  
      </plugin>
  
    </sensor>
  
  </gazebo>
  
  <!-- LIDAR -->
  <gazebo reference="lidar">

    <sensor name="lidar_sensor" type="ray">
  
      <always_on>true</always_on>
  
      <visualize>true</visualize>
  
      <update_rate>10</update_rate>
  
      <pose>0 0 0 0 0 0</pose>
  
      <ray>
  
        <scan>
  
          <horizontal>
  
            <samples>360</samples>
  
            <resolution>1</resolution>
  
            <min_angle>-3.14159</min_angle>
  
            <max_angle>3.14159</max_angle>
  
          </horizontal>
  
        </scan>
  
        <range>
  
          <min>0.12</min>
  
          <max>12.0</max>
  
          <resolution>0.01</resolution>
  
        </range>
  
        <noise>
  
          <type>gaussian</type>
  
          <mean>0.0</mean>
  
          <stddev>0.01</stddev>
  
        </noise>
  
      </ray>
  
      <plugin name="laser_controller"
              filename="libgazebo_ros_ray_sensor.so">
  
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
  
        <output_type>sensor_msgs/LaserScan</output_type>
  
        <frame_name>lidar</frame_name>
  
      </plugin>
  
    </sensor>
  
  </gazebo>
</robot>